# Copy to .env (local) or set these in your host's dashboard. NEVER commit real keys.

# --- Alpaca paper-trading credentials (per bot, prefix matches METADATA env_prefix) ---
ALPACA_API_KEY=your_paper_key_id
ALPACA_API_SECRET=your_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Platform settings ---
POLL_SECONDS=60
SEED_START_DATE=2026-01-01
SEED_INITIAL_CAPITAL=100000
